# Databricks Serving Endpoint Configuration
# Note: For production security, do not commit your real secrets to Git.
# Keep these in your hosting environment's secret settings (e.g., Vercel, Netlify).

VITE_DATABRICKS_ENDPOINT_URL=https://<your-databricks-workspace-url>/serving-endpoints/<endpoint-name>/invocations
VITE_DATABRICKS_TOKEN=dapi_your_databricks_personal_access_token_here

# Footer Social Media Links
# Replace these with your actual profiles
VITE_LINKEDIN_URL=https://linkedin.com/in/mohitsharma
VITE_GITHUB_URL=https://github.com/mohitsharma
